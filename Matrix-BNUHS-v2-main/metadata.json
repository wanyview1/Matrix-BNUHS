{
  "name": "附中矩阵 (BNU-MATRIX)",
  "description": "基于 EDU-MATRIX V1.3 社会中心生成式认知数字孪生架构。北京师范大学附属中学赛博智能体管理平台。集成环境上下文注入引擎(ECIE)、模块化逻辑演化协议(MLEP)、社交拓扑对齐模块(STAM)和历史复现知识胶囊系统。",
  "version": "1.3.0",
  "requestFramePermissions": [
    "camera",
    "microphone",
    "geolocation"
  ],
  "basedOn": {
    "paper": "EDU-MATRIX: A Society-Centric Generative Cognitive Digital Twin Architecture for Secondary Education",
    "venue": "ACM CHI 2026",
    "authors": ["Wenjing Zhai", "Jianbin Zhang", "Tao Liu"]
  },
  "features": {
    "ecie": {
      "name": "环境上下文注入引擎",
      "description": "基于空间位置动态注入规则，Rules = Gravity",
      "enabled": true
    },
    "mlep": {
      "name": "模块化逻辑演化协议",
      "description": "知识胶囊融合，跨学科知识流动",
      "enabled": true
    },
    "stam": {
      "name": "社交拓扑对齐模块",
      "description": "从社交图谱涌现安全约束，Agents = Coordinates",
      "enabled": true
    },
    "historical_replication": {
      "name": "历史复现知识胶囊",
      "description": "集成5个历史复现案例，连接历史与未来的知识创新",
      "enabled": true
    },
    "knowledge_salon": {
      "name": "知识沙龙场景",
      "description": "在数字孪生校园中开展历史复现知识讨论",
      "enabled": true
    },
    "ui_components": {
      "name": "前端UI组件",
      "description": "知识沙龙面板和演示页面",
      "enabled": true
    }
  },
  "targets": {
    "dialogueConsistency": "95.1%",
    "globalResonanceSync": "98.8%",
    "socialClusteringCoefficient": "0.75",
    "valueInjectionEfficacy": "48%"
