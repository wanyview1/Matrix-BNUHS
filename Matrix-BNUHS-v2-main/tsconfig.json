
{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "noImplicitAny": false
  },
  "include": ["./App.tsx", "./main.tsx", "./index.tsx", "./components/AgentCard.tsx", "./components/SalonPanel.tsx", "./components/ChatInterface.tsx", "./components/KnowledgeBank.tsx", "./components/SimulationPanel.tsx", "./components/ScenarioVisualizer.tsx", "./components/SynthesisLab.tsx", "./components/MissionControl.tsx", "./components/LiveLink.tsx", "./components/GeospatialView.tsx", "./constants.ts", "./types.ts", "./config/"],
  "exclude": ["node_modules", "services", "scripts", "docs"]
}
